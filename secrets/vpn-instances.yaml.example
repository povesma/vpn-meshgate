# VPN Instance Configuration
#
# Define N company VPN tunnels. Each instance gets its own container
# on bridge_vpn with CIDR-based routing.
#
# Copy to secrets/vpn-instances.yaml and fill in real values.
# Run: python3 generate-vpn.py
#   → produces docker-compose.override.yml
#   → produces vpn-instances.json
#   → produces .env.vpn-{name} per instance (secrets, 0600)
#
# Then: docker compose up -d --build
#
# IMPORTANT: If any instance has dns_domains, you must also set
# VPN_DNS_DOMAINS in .env with all domains (*.domain format) so
# gluetun allows private-IP DNS responses. Example:
#   VPN_DNS_DOMAINS=*.company-a.com,*.company-b.com
#
# Supported tunnel types: l2tp, wireguard, openvpn, netbird

instances:
  # --- L2TP/IPsec example ---
  - name: company-a
    type: l2tp
    server: vpn.company-a.com
    cidrs:
      - 10.11.0.0/16
      - 10.12.0.0/16
    # dns_domains: which DNS server resolves the domain (split DNS)
    # route_domains: route resolved IPs through this VPN instance
    # Use both together when a domain needs company DNS AND routing.
    # Use route_domains alone for publicly-resolvable domains on
    # public IPs that require VPN source IP for access.
    dns_domains:
      - company-a.com
    route_domains:
      - git.company-a.com
      - ci.company-a.com
      - jira.company-a.com
    check_ip: 10.11.0.1
    credentials:
      username: user
      password: pass
      psk: shared-secret

  # --- WireGuard example ---
  - name: company-b
    type: wireguard
    cidrs:
      - 10.21.0.0/16
    check_ip: 10.21.0.1
    config_file: wireguard/compb.conf

  # --- OpenVPN example ---
  - name: company-c
    type: openvpn
    cidrs:
      - 10.31.0.0/16
    check_ip: 10.31.0.1
    config_file: openvpn/compc.ovpn
    credentials:
      username: user
      password: pass

  # --- Netbird example ---
  # Netbird uses domain-based routing: the management server pushes
  # domain routes to peers, and Netbird's DNS resolver automatically
  # adds resolved IPs to WireGuard allowed-IPs. Put only the overlay
  # network in cidrs. Public IPs are handled dynamically via dns_domains.
  - name: company-d
    type: netbird
    cidrs:
      - 10.41.0.0/16
    dns_domains:
      - company-d.com
    route_domains:
      - portal.company-d.com
    check_ip: 10.41.0.1
    credentials:
      setup_key: XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
    # management_url: https://api.netbird.io:443
