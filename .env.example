# --- Tailscale / Headscale ---
TS_AUTHKEY=tskey-auth-xxxxx
TS_HOSTNAME=vpn-router
HEADSCALE_URL=https://headscale.example.com

# --- Test client (profile: test) ---
TS_TEST_CLIENT_AUTHKEY=tskey-auth-xxxxx

# --- Mullvad ---
WIREGUARD_PRIVATE_KEY=xxxxx
WIREGUARD_ADDRESSES=10.66.x.x/32
MULLVAD_COUNTRY=Turkey

# --- Company VPN instances ---
# Configured in secrets/vpn-instances.yaml (see secrets/vpn-instances.yaml.example)
# Run: python3 generate-vpn.py
#
# VPN_DNS_DOMAINS: all dns_domains from vpn-instances.yaml in *.domain format.
# Used by gluetun DNS rebinding protection to allow private-IP responses.
VPN_DNS_DOMAINS=*.company-a.com,*.company-b.com
#
# VPN_ADVERTISE_ROUTES: all CIDRs from vpn-instances.yaml, comma-separated.
# Used by Tailscale --advertise-routes so private CIDRs are routed through
# the exit node instead of being dropped. Requires Headscale route approval.
VPN_ADVERTISE_ROUTES=10.11.0.0/16,10.21.0.0/16

# --- Health Check ---
VPS_PUBLIC_IP=203.0.113.1
CHECK_INTERVAL=30

# --- ntfy ---
NTFY_TOPIC=vpn-alerts
NTFY_CMD_TOPIC=vpn-cmd

# --- Gluetun HTTP control server ---
# Used by vpn-bot to hot-switch Mullvad country via API. Must match
# the apikey in gluetun/auth/config.toml (create from config.toml.example).
GLUETUN_API_KEY=change-me
